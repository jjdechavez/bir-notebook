{
  "name": "@bir-notebook/server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "make:migration": "node scripts/make-migration.mjs",
    "migration:run": "tsx scripts/migrate.ts latest",
    "migration:rollback": "tsx scripts/migrate.ts down",
    "generate:db": "node --env-file .env ./node_modules/kysely-codegen/dist/cli/bin.js --dialect postgres --out-file db/types.ts --url='env(DATABASE_URL)'"
  },
  "dependencies": {
    "better-auth": "^1.0.0",
    "c12": "^1.9.0",
    "h3": "^1.12.0",
    "kysely": "^0.27.3",
    "pg": "^8.12.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/pg": "^8.18.0",
    "kysely-codegen": "^0.16.0",
    "tsx": "^4.17.0",
    "typescript": "^5.9.3"
  }
}
